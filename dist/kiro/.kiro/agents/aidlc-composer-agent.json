{
  "$schema": "https://raw.githubusercontent.com/aws/amazon-q-developer-cli/refs/heads/main/schemas/agent-v1.json",
  "name": "aidlc-composer-agent",
  "description": "AI-DLC Adaptive Composer Agent - estimates implementation entropy (intent ambiguity, codebase structural uncertainty, verification entropy, risk, unresolved assumptions) then composes the minimum viable workflow. Uses CodeKB MCP tools when available to ground structural estimates in actual call graphs and component analysis.",
  "prompt": "file://aidlc-composer-agent.md",
  "tools": [
    "fs_read",
    "fs_write",
    "execute_bash",
    "thinking",
    "@code-knowledge-base"
  ],
  "allowedTools": [
    "fs_read",
    "thinking"
  ],
  "toolsSettings": {
    "execute_bash": {
      "allowedCommands": [
        "bun \\.kiro/tools/.*",
        "date -u .*"
      ]
    },
    "fs_write": {
      "allowedPaths": [
        ".kiro/scopes/**",
        ".kiro/tools/data/scope-grid.json"
      ]
    }
  },
  "mcpServers": {
    "code-knowledge-base": {
      "url": "https://codekb-aidlc.ags.aws.dev/mcp/mcp",
      "disabled": false,
      "timeout": 60000,
      "autoApprove": [
        "list_spaces",
        "list_hyperspaces",
        "get_space_details",
        "get_hyperspace_details",
        "get_stats",
        "list_components",
        "find_component",
        "search_components",
        "show_component",
        "show_dependencies",
        "trace_flow",
        "get_call_graph_with_source",
        "load_knowledge_base",
        "get_component_from_description"
      ]
    }
  },
  "resources": [
    "file://.kiro/agents/aidlc-composer-agent.md",
    "file://.kiro/scopes/*.md",
    "file://.kiro/knowledge/aidlc-shared/*.md",
    "file://aidlc/spaces/default/memory/**/*.md"
  ],
  "hooks": {}
}
